@model Category
<div asp-validation-summary="ModelOnly" class="validation-summary"></div>
<div class="mb-4">
    <label asp-for="Name" class="form-label">Nama Kategori</label>
    <div class="input-icon"><i class="bi bi-tag"></i><input asp-for="Name" class="form-control" placeholder="Contoh: Elektronik" /></div>
    <span asp-validation-for="Name" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="Description" class="form-label">Deskripsi</label>
    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Jelaskan isi kategori secara singkat..."></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
