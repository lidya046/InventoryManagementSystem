@model Product
@{ ViewData["Title"] = "Hapus Produk"; }
<div class="confirm-card"><div class="confirm-icon danger"><i class="bi bi-trash3-fill"></i></div><span class="page-eyebrow">KONFIRMASI PENGHAPUSAN</span><h2>Hapus produk?</h2><p>Produk <strong>@Model.Code - @Model.Name</strong> akan dihapus permanen. Tindakan ini tidak dapat dibatalkan.</p><form asp-action="Delete"><input type="hidden" asp-for="Id" /><div class="d-flex justify-content-center gap-2"><a asp-action="Index" class="btn btn-light">Batal</a><button class="btn btn-danger btn-icon-label"><i class="bi bi-trash3"></i> Ya, Hapus Produk</button></div></form></div>
