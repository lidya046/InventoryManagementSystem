@model Product
@{ ViewData["Title"] = "Detail Produk"; var isLow = Model.Stock <= Model.MinimumStock; }
<div class="page-heading"><div><span class="page-eyebrow">INFORMASI PRODUK</span><h2>@Model.Name</h2><p>Kode produk: @Model.Code</p></div><div class="d-flex gap-2"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-light btn-icon-label"><i class="bi bi-pencil"></i> Edit</a><a asp-controller="StockTransactions" asp-action="Create" asp-route-productId="@Model.Id" class="btn btn-primary btn-icon-label"><i class="bi bi-arrow-left-right"></i> Transaksi Stok</a></div></div>
<div class="row g-4">
    <div class="col-lg-4"><div class="product-profile-card"><div class="product-profile-icon"><i class="bi bi-box-seam"></i></div><h3>@Model.Name</h3><span class="category-chip"><i class="bi bi-tag"></i> @Model.Category?.Name</span><div class="stock-big @(isLow ? "low" : "")"><strong>@Model.Stock</strong><span>@Model.Unit tersedia</span></div><div class="stock-minimum">Minimum stok: <strong>@Model.MinimumStock @Model.Unit</strong></div></div></div>
    <div class="col-lg-8"><div class="panel-card h-100"><div class="panel-header"><div><span class="panel-eyebrow">RINCIAN</span><h3>Informasi Lengkap</h3></div></div><div class="detail-grid"><div><span>Kode Produk</span><strong>@Model.Code</strong></div><div><span>Kategori</span><strong>@Model.Category?.Name</strong></div><div><span>Harga Beli</span><strong>Rp @Model.PurchasePrice.ToString("N0")</strong></div><div><span>Harga Jual</span><strong>Rp @Model.SellingPrice.ToString("N0")</strong></div><div><span>Margin per Unit</span><strong class="text-success">Rp @((Model.SellingPrice - Model.PurchasePrice).ToString("N0"))</strong></div><div><span>Nilai Stok</span><strong>Rp @((Model.PurchasePrice * Model.Stock).ToString("N0"))</strong></div><div><span>Dibuat</span><strong>@Model.CreatedAt.ToString("dd MMM yyyy")</strong></div><div><span>Terakhir Diperbarui</span><strong>@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</strong></div></div></div></div>
</div>
<div class="mt-4"><a asp-action="Index" class="btn btn-light"><i class="bi bi-arrow-left"></i> Kembali ke Produk</a></div>
