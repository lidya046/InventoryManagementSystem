@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#111827" />
    <title>@pageTitle - StockFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app-shell">
    <aside class="offcanvas-lg offcanvas-start app-sidebar" tabindex="-1" id="appSidebar" aria-labelledby="appSidebarLabel">
        <div class="offcanvas-header d-lg-none border-bottom border-secondary border-opacity-25">
            <h5 class="offcanvas-title text-white" id="appSidebarLabel">StockFlow</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#appSidebar" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column p-0">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark"><i class="bi bi-box-seam-fill"></i></span>
                <span>
                    <strong>StockFlow</strong>
                    <small>Inventory Management</small>
                </span>
            </a>

            <div class="sidebar-label">MENU UTAMA</div>
            <nav class="sidebar-nav">
                <a class="sidebar-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
                </a>
                <a class="sidebar-link @(currentController == "Products" ? "active" : "")" asp-controller="Products" asp-action="Index">
                    <i class="bi bi-box2-fill"></i><span>Produk</span>
                </a>
                <a class="sidebar-link @(currentController == "Categories" ? "active" : "")" asp-controller="Categories" asp-action="Index">
                    <i class="bi bi-tags-fill"></i><span>Kategori</span>
                </a>
                <a class="sidebar-link @(currentController == "StockTransactions" ? "active" : "")" asp-controller="StockTransactions" asp-action="Index">
                    <i class="bi bi-arrow-left-right"></i><span>Transaksi Stok</span>
                </a>
            </nav>

            <div class="sidebar-help mt-auto">
                <div class="help-icon"><i class="bi bi-lightning-charge-fill"></i></div>
                <div>
                    <strong>Kelola stok lebih cepat</strong>
                    <p>Pantau produk dan transaksi dalam satu tempat.</p>
                </div>
            </div>
            <div class="sidebar-footer">StockFlow v1.0</div>
        </div>
    </aside>

    <div class="app-content">
        <header class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn sidebar-toggle d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar">
                    <i class="bi bi-list"></i>
                </button>
                <div>
                    <div class="topbar-kicker">INVENTORY MANAGEMENT</div>
                    <h1 class="topbar-title">@pageTitle</h1>
                </div>
            </div>
            <div class="topbar-actions">
                <div class="date-chip d-none d-md-flex">
                    <i class="bi bi-calendar3"></i>
                    <span>@DateTime.Now.ToString("dd MMM yyyy")</span>
                </div>
                <a asp-controller="StockTransactions" asp-action="Create" class="btn btn-primary btn-icon-label">
                    <i class="bi bi-plus-lg"></i><span class="d-none d-sm-inline">Transaksi Baru</span>
                </a>
            </div>
        </header>

        <main class="page-content">
            @if (TempData["Success"] is not null)
            {
                <div class="alert app-alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <div>@TempData["Success"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] is not null)
            {
                <div class="alert app-alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>

        <footer class="app-footer">
            <span>&copy; @DateTime.Now.Year StockFlow Inventory System</span>
            <span>Dibuat dengan ASP.NET Core</span>
        </footer>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
