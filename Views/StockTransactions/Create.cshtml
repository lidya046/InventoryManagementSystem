@model StockTransactionViewModel
@{ ViewData["Title"] = "Transaksi Baru"; }
<div class="page-heading compact"><div><span class="page-eyebrow">PERGERAKAN PERSEDIAAN</span><h2>Catat Transaksi Stok</h2><p>Tambahkan stok masuk atau kurangi stok keluar dengan aman.</p></div></div>
<div class="panel-card form-page-card narrow-card">
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <div class="mb-4"><label asp-for="ProductId" class="form-label">Produk</label><div class="input-icon"><i class="bi bi-box"></i><select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-select"><option value="">Pilih produk</option></select></div><span asp-validation-for="ProductId" class="text-danger"></span></div>
    <div class="mb-4"><label asp-for="Type" class="form-label">Jenis Transaksi</label><div class="input-icon"><i class="bi bi-arrow-left-right"></i><select asp-for="Type" asp-items="Html.GetEnumSelectList<TransactionType>()" class="form-select"></select></div><span asp-validation-for="Type" class="text-danger"></span></div>
    <div class="mb-4"><label asp-for="Quantity" class="form-label">Jumlah</label><div class="input-icon"><i class="bi bi-123"></i><input asp-for="Quantity" class="form-control" /></div><span asp-validation-for="Quantity" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Note" class="form-label">Catatan</label><textarea asp-for="Note" class="form-control" rows="4" placeholder="Contoh: Pembelian dari supplier atau penjualan toko"></textarea><span asp-validation-for="Note" class="text-danger"></span></div>
    <div class="transaction-hint"><i class="bi bi-shield-check"></i><span>Sistem otomatis menolak stok keluar jika jumlah melebihi stok tersedia.</span></div>
    <div class="form-actions"><a asp-action="Index" class="btn btn-light">Batal</a><button class="btn btn-primary btn-icon-label"><i class="bi bi-check-lg"></i> Simpan Transaksi</button></div>
</form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
